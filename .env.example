# ===== SES業務管理システム 環境変数（Vercel + Supabase）=====

# Supabase コネクションプーラー（実行時用・port 6543・pgbouncer）
# Supabase ダッシュボード → Project Settings → Database → Connection string → "Transaction" を使用
DATABASE_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase 直結（マイグレーション/seed用・port 5432）
# Connection string の "Session" を使用
DIRECT_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# セッション署名キー（本番では必ず長いランダム文字列に変更）
# 生成例: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-in-production-please-use-long-random-string"
